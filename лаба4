#include <stdio.h>
#include <sys/types.h>
#include <unistd.h>
#include <stdlib.h>

int main(int argc, char *argv[])
{
    pid_t pid;
    int x;

    pid = getpid();
    printf("PID программы: %d\n", pid);

    if (argc > 1)
    {
        x = atoi(argv[1]);
        nice(x);
        printf("Приоритет изменен на значение: %d\n", x);
    }
    else
    {
        printf("Аргумент не передан, приоритет не изменяется\n");
    }

    while (1)
    {
    }

    return 0;
}
